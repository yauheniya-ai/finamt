# finamt — copy to .env and adjust

# LLM — models are downloaded automatically from HuggingFace on first use (~4 GB)
# Supported: mistral:7b | qwen2.5:7b-instruct-q4_K_M
FINAMT_AGENT_MODEL=mistral:7b
FINAMT_AGENT_NUM_CTX=4096
FINAMT_AGENT_MAX_RETRIES=3
FINAMT_AGENT_TIMEOUT=60

# OCR
FINAMT_OCR_LANGUAGE=german
FINAMT_OCR_TIMEOUT=60
FINAMT_OCR_PREPROCESS=true
FINAMT_TESSERACT_CMD=tesseract
FINAMT_PDF_DPI=300

# ELSTER / E-Bilanz (ERiC)
FINAMT_ERIC_HOME=/path/to/ERiC-43.4.6.0/Darwin-universal/lib
FINAMT_ELSTER_CERT_PATH=~/.finamt/default/elster_cert.pfx
FINAMT_ELSTER_CERT_PASSWORD=your_certificate_pin
FINAMT_ELSTER_STEUERNUMMER=21/815/12345
FINAMT_ELSTER_FINANZAMT_NR=2181
FINAMT_ELSTER_BUNDESLAND_KZ=21
